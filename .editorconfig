# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across Xcode, VS Code, and Android Studio

root = true

# ── Global defaults ──────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ── Swift ────────────────────────────────────────
[*.swift]
indent_style = space
indent_size = 4

# ── Kotlin ───────────────────────────────────────
[*.{kt,kts}]
indent_style = space
indent_size = 4

# ── XML (Android layouts, manifests, plists) ─────
[*.{xml,plist,storyboard,xib}]
indent_style = space
indent_size = 4

# ── JSON ─────────────────────────────────────────
[*.json]
indent_style = space
indent_size = 2

# ── YAML / TOML (CI config, Gitleaks, etc.) ──────
[*.{yml,yaml,toml}]
indent_style = space
indent_size = 2

# ── Markdown (trailing spaces = line break) ──────
[*.md]
trim_trailing_whitespace = false

# ── Shell scripts ────────────────────────────────
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# ── Makefiles (tabs are required) ────────────────
[Makefile]
indent_style = tab

# ── Gradle build files ───────────────────────────
[*.gradle]
indent_style = space
indent_size = 4
