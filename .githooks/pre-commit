#!/usr/bin/env bash

# Pre-commit hook
# 1. Runs Gitleaks on staged files to detect secrets
# 2. Runs SwiftLint on staged Swift files to enforce lint rules
# Blocks commit if either check finds errors

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

# ============================================
# STEP 1: Gitleaks — Secrets Detection
# ============================================

GITLEAKS=$(command -v gitleaks 2>/dev/null || true)
if [ -z "$GITLEAKS" ]; then
    echo "⚠️  Gitleaks not found — skipping secrets scan"
    echo "   Install with: brew install gitleaks"
else
    GITLEAKS_CONFIG="$REPO_ROOT/.gitleaks.toml"

    # Get list of staged files (Added, Copied, Modified)
    STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)
    if [ -n "$STAGED_ALL" ]; then
        echo "Running Gitleaks on staged files..."

        # Write staged file paths to a temp file for scanning
        TMPDIR_GITLEAKS=$(mktemp -d)
        trap "rm -rf $TMPDIR_GITLEAKS" EXIT

        # Copy staged file contents to temp dir (preserving directory structure)
        while IFS= read -r file; do
            if [ -f "$REPO_ROOT/$file" ]; then
                mkdir -p "$TMPDIR_GITLEAKS/$(dirname "$file")"
                # Use git show to get the staged version (not working tree)
                git show ":$file" > "$TMPDIR_GITLEAKS/$file" 2>/dev/null || true
            fi
        done <<< "$STAGED_ALL"

        GITLEAKS_ARGS="dir --no-banner --verbose $TMPDIR_GITLEAKS"
        if [ -f "$GITLEAKS_CONFIG" ]; then
            GITLEAKS_ARGS="-c $GITLEAKS_CONFIG dir --no-banner --verbose $TMPDIR_GITLEAKS"
        fi

        if ! $GITLEAKS $GITLEAKS_ARGS; then
            echo ""
            echo "❌ Gitleaks found secrets in staged files. Remove them before committing."
            echo "   To bypass: git commit --no-verify"
            exit 1
        fi

        echo "✅ Gitleaks passed — no secrets detected"
    fi
fi

# ============================================
# STEP 2: SwiftLint — Code Linting
# ============================================

SWIFTLINT=$(command -v swiftlint 2>/dev/null || true)
if [ -z "$SWIFTLINT" ]; then
    echo "⚠️  SwiftLint not found — skipping lint check"
    echo "   Install with: brew install swiftlint"
    exit 0
fi

# Get staged Swift files (Added, Copied, Modified only)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift' || true)
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

SWIFTLINT_CONFIG="$REPO_ROOT/iOS/.swiftlint.yml"

if [ ! -f "$SWIFTLINT_CONFIG" ]; then
    echo "⚠️  SwiftLint config not found at iOS/.swiftlint.yml — skipping lint check"
    exit 0
fi

echo "Running SwiftLint on $(echo "$STAGED_FILES" | wc -l | tr -d ' ') staged Swift file(s)..."

LINT_ERRORS=0

while IFS= read -r file; do
    # Only lint files that still exist (not deleted)
    if [ -f "$REPO_ROOT/$file" ]; then
        OUTPUT=$("$SWIFTLINT" lint --config "$SWIFTLINT_CONFIG" "$REPO_ROOT/$file" 2>&1 || true)
        if echo "$OUTPUT" | grep -q ": error:"; then
            echo "$OUTPUT"
            LINT_ERRORS=1
        elif [ -n "$OUTPUT" ]; then
            # Show warnings but don't fail
            echo "$OUTPUT"
        fi
    fi
done <<< "$STAGED_FILES"

if [ "$LINT_ERRORS" -ne 0 ]; then
    echo ""
    echo "❌ SwiftLint found errors. Fix them before committing."
    echo "   To bypass: git commit --no-verify"
    exit 1
fi

echo "✅ SwiftLint passed"
exit 0
