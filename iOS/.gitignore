# SPM Packages
# Ignore resolved files inside dependency checkouts, but commit the app's own
# Package.resolved so CI resolves the exact same versions as local (prevents
# drift to broken upstream manifests, e.g. swiftui-cached-async-image 2.1.2).
Package.resolved
!meApp.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Swift Package Manager
.swiftpm/

# Xcode Patch
*.xcodeproj/*/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/

# User Interface State files
*.xcuserstate

# Generated coverage reports
meAppTests/Reports/
meAppUITests/Reports/

# IDEWorkspaceChecks
.idea/
.idea/*

# Local Pods
Pods/
