# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
max_line_length = 120

[*.{kt,kts}]
indent_size = 4
insert_final_newline = true
ij_kotlin_imports_layout = *, java.**, javax.**, kotlin.**, android.**
ij_kotlin_align_multiline_parameters = true
ij_kotlin_allow_trailing_comma = true
ij_formatter_off_tag = @formatter:off
ij_formatter_on_tag = @formatter:on
ij_kotlin_align_multiline_parameters_in_calls = true
ij_kotlin_keep_indents_on_empty_lines = true
# Apply Kotlin official code style
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL
# Disable wildcard imports
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647
ij_kotlin_packages_to_use_import_on_demand = unset
# Minimize blank lines
ij_kotlin_keep_blank_lines_before_right_brace = 0
ij_kotlin_keep_blank_lines_in_code = 1
ij_kotlin_keep_blank_lines_in_declarations = 1
# Add space after //
ij_kotlin_line_comment_add_space = true
ij_kotlin_line_comment_add_space_on_reformat = true
ij_kotlin_line_comment_at_first_column = false
# Force trailing comma.
ij_kotlin_allow_trailing_comma_on_call_site = true
ktlint_function_naming_ignore_annotated = Composable,Preview

[*.java]
indent_size = 4
insert_final_newline = true
ij_java_imports_layout = *, java.**, javax.**, android.**

[*.xml]
indent_size = 4

[*.gradle]
indent_size = 4

