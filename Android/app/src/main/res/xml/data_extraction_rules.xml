<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<!--    Android 12+ Backup / Restore / Transfer rules (data-extraction-rules)-->
<!--    Notes:-->
<!--    - "file", "database", "sharedpref", "root", "external" are the normal app storage-->
<!--    domains (credential-protected storage / CE): available after the user unlocks.-->
<!--    - Even if android:allowBackup="false" is set, keeping explicit rules helps protect-->
<!--    against future manifest changes / build flavors and makes intent clear.-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="root" path="."/>
        <exclude domain="external" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
