<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for release (and default).
  Cleartext (HTTP) is disabled; all traffic must use HTTPS.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
