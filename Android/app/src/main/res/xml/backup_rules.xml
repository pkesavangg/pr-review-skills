<?xml version="1.0" encoding="utf-8"?><!--
   Sample backup rules file; uncomment and customize as necessary.
   See https://developer.android.com/guide/topics/data/autobackup
   for details.
   Note: This file is ignored for devices older than API 31
   See https://developer.android.com/about/versions/12/backup-restore
-->

<!--
  Legacy Auto Backup rules (full-backup-content) for Android 11 and below.
  Goal:
  - Prevent older Android versions from backing up / restoring any local app data.
  Notes:
  - On Android 12+ (API 31+) this file is generally superseded by
    android:dataExtractionRules, but we keep it for older devices and clarity.
  - We exclude CE (normal) domains for future-proofing.
-->

<full-backup-content>
    <!-- Exclude everything from normal app storage (CE) -->
    <exclude domain="file" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="external" path="."/>
    <exclude domain="root" path="."/>
</full-backup-content>
