<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MeApp" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Text selection handle colors -->
        <item name="android:textSelectHandle">@color/me_text</item>
        <item name="android:textSelectHandleLeft">@color/me_text</item>
        <item name="android:textSelectHandleRight">@color/me_text</item>
        <item name="android:textCursorDrawable">@color/me_text</item>
        <item name="android:colorControlActivated">@color/me_text</item>

        <!-- Text selection highlight color -->
        <item name="android:textColorHighlight">#4D65CEC8</item>  <!-- Teal color with 30% opacity -->
    </style>

    <style name="Theme.Splash" parent="Theme.MeApp">
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="postSplashScreenTheme">@style/Theme.MeApp</item>
    </style>
</resources>
